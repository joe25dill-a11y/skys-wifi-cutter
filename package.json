{
  "name": "skys-wifi-cutter",
  "private": true,
  "version": "4.4.0",
  "description": "Skys WiFi Cutter — free LAN network manager",
  "author": "Skys WiFi Cutter",
  "type": "module",
  "main": "electron/main.mjs",
  "scripts": {
    "dev": "vite",
    "dev:all": "concurrently -n server,web -c blue,green \"npm run server\" \"npm run dev\"",
    "build": "vite build",
    "start": "node server/index.js",
    "desktop": "npm run build && electron .",
    "bundle:runtime": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/bundle-runtime.ps1",
    "bundle:windivert": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/bundle-windivert.ps1",
    "bundle:native": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/bundle-native.ps1",
    "generate:tray-icon": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/generate-tray-icon.ps1",
    "desktop:build": "npm run bundle:runtime && npm run bundle:windivert && npm run bundle:native && npm run generate:tray-icon && npm run build && npx electron-builder install-app-deps && electron-builder --win --config.directories.output=%LOCALAPPDATA%/SkysWiFiCutterBuild",
    "lint": "eslint .",
    "smoke": "node scripts/smoke-test.mjs",
    "audit": "node scripts/api-audit.mjs",
    "github:release": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/github-release.ps1",
    "repair": "npx electron-builder install-app-deps && npm run smoke",
    "postinstall": "electron-builder install-app-deps",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit -p tsconfig.app.json",
    "server": "node server/index.js",
    "setup:python": "py -m pip install scapy winrt-Windows.Networking.NetworkOperators winrt-Windows.Networking.Connectivity winrt-Windows.Foundation"
  },
  "dependencies": {
    "better-sqlite3": "^11.10.0",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "express": "^5.1.0",
    "express-rate-limit": "^8.2.1",
    "helmet": "^8.1.0",
    "joi": "^18.0.1",
    "lucide-react": "^0.344.0",
    "netmask": "^2.0.2",
    "oui-data": "^1.1.428",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hot-toast": "^2.6.0",
    "systeminformation": "^5.27.11",
    "validator": "^13.15.20",
    "winston": "^3.18.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.9.1",
    "@types/react": "^18.3.5",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.18",
    "concurrently": "^9.2.1",
    "electron": "^35.7.5",
    "electron-builder": "^26.0.12",
    "eslint": "^9.9.1",
    "eslint-plugin-react-hooks": "^5.1.0-rc.0",
    "eslint-plugin-react-refresh": "^0.4.11",
    "globals": "^15.9.0",
    "postcss": "^8.4.35",
    "tailwindcss": "^3.4.1",
    "typescript": "^5.5.3",
    "typescript-eslint": "^8.3.0",
    "vite": "^5.4.2"
  },
  "build": {
    "appId": "com.skys.wificutter",
    "productName": "Skys WiFi Cutter",
    "icon": "public/icon.ico",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "server/**/*",
      "scripts/**/*",
      "electron/**/*",
      "package.json",
      "node_modules/**/*"
    ],
    "extraResources": [
      {
        "from": "runtime/python",
        "to": "python",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "runtime/npcap",
        "to": "npcap",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "runtime/native",
        "to": "native",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "runtime/windivert",
        "to": "windivert",
        "filter": [
          "**/*"
        ]
      }
    ],
    "asarUnpack": [
      "dist/**/*",
      "scripts/**/*",
      "node_modules/systeminformation/**/*",
      "node_modules/better-sqlite3/**/*"
    ],
    "win": {
      "icon": "public/icon.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "requestedExecutionLevel": "requireAdministrator"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "shortcutName": "Skys WiFi Cutter",
      "runAfterFinish": false,
      "include": "build/installer.nsh"
    }
  }
}
